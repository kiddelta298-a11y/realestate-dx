# ============================================
# 不動産DX Platform - 環境変数
# ============================================
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# --- Database ---
POSTGRES_USER=realestate
POSTGRES_PASSWORD=realestate_dev
POSTGRES_DB=realestate_dx
DB_PORT=5432
DATABASE_URL=postgresql://realestate:realestate_dev@localhost:5432/realestate_dx

# --- Backend (Hono) ---
BACKEND_PORT=3001
JWT_SECRET=change-me-in-production

# --- Frontend (Next.js) ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Auth ---
# NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# NEXTAUTH_URL=http://localhost:3000

# --- iimon（いい物件速いもん）連携 ---
IIMON_EMAIL=your-iimon-email@example.com
IIMON_PASSWORD=your-iimon-password

# --- SUUMO自動投稿 ---
SUUMO_EMAIL=your-suumo-biz-email@example.com
SUUMO_PASSWORD=your-suumo-biz-password

# --- Replicate（バーチャルステージング） ---
REPLICATE_API_TOKEN=your-replicate-api-token
